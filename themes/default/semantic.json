      "secondary": {
        "bg":       { "$value": {
          "light": "{color.gray.100}", "dark": "{color.gray.800}",
          "dim": "{color.dim.sec}", "midnight": "{color.gray.900}", "high-contrast-light": "{color.gray.200}",
          "sepia": "{color.sepia.sec}", "solarized-light": "{color.solarized.base2}", "solarized-dark": "{color.solarized.base02}",
          "nord": "{color.nord.sec}", "love": "{color.love.sec}", "future": "{color.future.sec}",
          "synthwave": "{color.synthwave.sec}", "sakura": "{color.sakura.sec}", "forest": "{color.forest.sec}",
          "ocean": "{color.ocean.sec}", "coffee": "{color.coffee.sec}", "aurora": "{color.aurora.sec}"
        } },
        "fg":       { "$value": {
          "light": "{color.gray.900}", "dark": "{color.gray.50}", "high-contrast-light": "{color.black}",
          "dim": "{color.dim.text}",
          "sepia": "{color.sepia.text}", "solarized-light": "{color.solarized.base02}", "solarized-dark": "{color.solarized.base1}",
          "nord": "{color.nord.snow2}", "love": "{color.love.text}", "future": "{color.future.text}",
          "synthwave": "{color.synthwave.text}", "sakura": "{color.sakura.text}", "forest": "{color.forest.text}",
          "ocean": "{color.ocean.text}", "coffee": "{color.coffee.text}", "aurora": "{color.aurora.text}"
        } },
        "border":   { "$value": {
          "light": "{color.gray.300}", "dark": "{color.gray.700}",
          "dim": "{color.dim.line}", "midnight": "{color.gray.800}", "high-contrast-light": "{color.gray.500}",
          "sepia": "{color.sepia.line}", "solarized-light": "{color.solarized.base1}", "solarized-dark": "{color.solarized.base01}",
          "nord": "{color.nord.line}", "love": "{color.love.line}", "future": "{color.future.line}",
          "synthwave": "{color.synthwave.line}", "sakura": "{color.sakura.line}", "forest": "{color.forest.line}",
          "ocean": "{color.ocean.line}", "coffee": "{color.coffee.line}", "aurora": "{color.aurora.line}"
        } },
        "hover":    { "$value": { "light": "{color.gray.200}",  "dark": "{color.gray.700}" } },
        "active":   { "$value": { "light": "{color.gray.300}",  "dark": "{color.gray.600}" } },
        "disabled": { "$value": { "light": "{color.gray.100}",  "dark": "{color.gray.800}" } },
        "focus":    { "$value": { "light": "{color.blue.500}",  "dark": "{color.blue.400}" } }
      },
      "danger": {
        "bg":       { "$value": {
          "light": "{color.red.600}", "dark": "{color.red.600}", "high-contrast-dark": "{color.red.700}",
          "dim": "{color.dim.danger}", "high-contrast-light": "{color.red.700}",
          "sepia": "{color.sepia.danger}", "solarized-light": "{color.solarized.danger}", "solarized-dark": "{color.solarized.danger}",
          "nord": "{color.nord.danger}", "love": "{color.love.danger}", "future": "{color.future.danger}",
          "synthwave": "{color.synthwave.danger}", "sakura": "{color.sakura.danger}", "forest": "{color.forest.danger}",
          "ocean": "{color.ocean.danger}", "coffee": "{color.coffee.danger}", "aurora": "{color.aurora.danger}"
        } },
        "fg":       { "$value": { "light": "{color.white}",     "dark": "{color.white}" } },
        "border":   { "$value": {
          "light": "{color.red.600}", "dark": "{color.red.500}",
          "dim": "{color.dim.danger}", "high-contrast-light": "{color.red.700}",
          "sepia": "{color.sepia.danger}", "solarized-light": "{color.solarized.danger}", "solarized-dark": "{color.solarized.danger}",
          "nord": "{color.nord.danger}", "love": "{color.love.danger}", "future": "{color.future.danger}",
          "synthwave": "{color.synthwave.danger}", "sakura": "{color.sakura.danger}", "forest": "{color.forest.danger}",
          "ocean": "{color.ocean.danger}", "coffee": "{color.coffee.danger}", "aurora": "{color.aurora.danger}"
        } },
        "hover":    { "$value": { "light": "{color.red.700}",   "dark": "{color.red.400}" } },
        "active":   { "$value": { "light": "{color.red.700}",   "dark": "{color.red.600}" } },
        "disabled": { "$value": { "light": "{color.gray.300}",  "dark": "{color.gray.700}" } },
        "focus":    { "$value": { "light": "{color.red.500}",   "dark": "{color.red.400}" } }
      }
    }
  },
  "text": {
    "$type": "typography",
    "display": { "$value": { "fontFamily": "{font.family.sans}", "fontSize": "{font.size.2xl}", "fontWeight": "{font.weight.bold}", "lineHeight": "{font.lineHeight.tight}" } },
    "heading": { "$value": { "fontFamily": "{font.family.sans}", "fontSize": "{font.size.xl}", "fontWeight": "{font.weight.semibold}", "lineHeight": "{font.lineHeight.tight}" } },
    "body":    { "$value": { "fontFamily": "{font.family.sans}", "fontSize": "{font.size.md}", "fontWeight": "{font.weight.regular}", "lineHeight": "{font.lineHeight.normal}" } },
    "caption": { "$value": { "fontFamily": "{font.family.sans}", "fontSize": "{font.size.sm}", "fontWeight": "{font.weight.regular}", "lineHeight": "{font.lineHeight.normal}" } }
  },
  "space": {
    "$type": "dimension",
    "inset": {
      "sm": { "$value": "{space.2}" },
      "md": { "$value": "{space.4}" },
      "lg": { "$value": "{space.6}" }
    }
  },
  "radius": {
    "$type": "dimension",
    "control": { "$value": "{radius.md}" },
    "surface": { "$value": "{radius.lg}" }
  },
  "elevation": {
    "$type": "shadow",
    "card":    { "$value": "{shadow.1}" },
    "popover": { "$value": "{shadow.2}" },
    "modal":   { "$value": "{shadow.3}" }
  },
  "motion": {
    "enter": { "$type": "duration", "$value": "{duration.normal}" },
    "exit":  { "$type": "duration", "$value": "{duration.fast}" }
  }
}
