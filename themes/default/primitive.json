  "space": {
    "$type": "dimension",
    "0": { "$value": "0px" },
    "1": { "$value": "4px" },
    "2": { "$value": "8px" },
    "3": { "$value": "12px" },
    "4": { "$value": "16px" },
    "5": { "$value": "20px" },
    "6": { "$value": "24px" },
    "8": { "$value": "32px" },
    "10": { "$value": "40px" },
    "12": { "$value": "48px" },
    "16": { "$value": "64px" }
  },
  "radius": {
    "$type": "dimension",
    "none": { "$value": "0px" },
    "sm": { "$value": "4px" },
    "md": { "$value": "8px" },
    "lg": { "$value": "12px" },
    "xl": { "$value": "16px" },
    "full": { "$value": "9999px" }
  },
  "font": {
    "family": {
      "$type": "fontFamily",
      "sans": { "$value": "system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif" },
      "mono": { "$value": "ui-monospace, 'Cascadia Code', 'Fira Code', monospace" }
    },
    "size": {
      "$type": "fontSize",
      "xs": { "$value": "12px" },
      "sm": { "$value": "14px" },
      "md": { "$value": "16px" },
      "lg": { "$value": "20px" },
      "xl": { "$value": "24px" },
      "2xl": { "$value": "32px" }
    },
    "weight": {
      "$type": "fontWeight",
      "regular": { "$value": 400 },
      "medium": { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold": { "$value": 700 }
    },
    "lineHeight": {
      "$type": "lineHeight",
      "tight": { "$value": 1.2 },
      "normal": { "$value": 1.5 },
      "relaxed": { "$value": 1.7 }
    }
  },
  "duration": {
    "$type": "duration",
    "instant": { "$value": "0ms" },
    "fast": { "$value": "150ms" },
    "normal": { "$value": "250ms" },
    "slow": { "$value": "400ms" }
  },
  "easing": {
    "$type": "cubicBezier",
    "standard": { "$value": [0.2, 0, 0, 1] },
    "emphasized": { "$value": [0.3, 0, 0.8, 0.15] }
  },
  "shadow": {
    "$type": "shadow",
    "1": {
      "$value": { "color": "#0000001a", "offsetX": "0px", "offsetY": "1px", "blur": "2px", "spread": "0px" }
    },
    "2": {
      "$value": { "color": "#00000026", "offsetX": "0px", "offsetY": "4px", "blur": "8px", "spread": "-1px" }
    },
    "3": {
      "$value": { "color": "#00000033", "offsetX": "0px", "offsetY": "12px", "blur": "24px", "spread": "-4px" }
    }
  }
}
