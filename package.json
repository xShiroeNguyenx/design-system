{
  "name": "dsmcp",
  "version": "0.1.0",
  "description": "Theme Governance MCP — contract + enforcement for consistent, mode-aware design systems (DTCG tokens, N color modes, independent typeface axis, 4 stacks).",
  "type": "module",
  "bin": {
    "dsmcp": "./dist/cli.js",
    "dsmcp-mcp": "./dist/mcp/server.js"
  },
  "main": "./dist/engine/index.js",
  "types": "./dist/engine/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/engine/index.d.ts",
      "import": "./dist/engine/index.js"
    }
  },
  "files": [
    "dist/**/*",
    "themes/**/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "start": "node dist/mcp/server.js",
    "cli": "node dist/cli.js",
    "test": "npm run build && node test/smoke-mcp.mjs && node test/verify-scaffold.mjs && node test/verify-validator.mjs && node test/verify-importer.mjs",
    "doctor": "node dist/cli.js doctor",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "design-system",
    "design-tokens",
    "dtcg",
    "theme",
    "governance",
    "dark-mode",
    "tailwind",
    "css-variables",
    "flutter",
    "accessibility",
    "wcag"
  ],
  "license": "MIT",
  "author": "xShiroeNguyenx (https://github.com/xShiroeNguyenx)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xShiroeNguyenx/design-system.git"
  },
  "bugs": {
    "url": "https://github.com/xShiroeNguyenx/design-system/issues"
  },
  "homepage": "https://github.com/xShiroeNguyenx/design-system#readme",
  "engines": {
    "node": ">=18.18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "postcss": "^8.5.15",
    "zod": "^3.23.0 || ^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
